{
  "name": "mira-health-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/qrcode": "^1.5.6",
    "expo": "~56.0.8",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "fflate": "^0.8.2",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "node scripts/build-site.mjs",
    "build:showcase": "expo export --platform web --output-dir dist/showcase",
    "chat:quality": "node scripts/mira-chat-quality-check.mjs",
    "chat:regression": "node scripts/chat-regression.mjs",
    "chat:regression:v3": "node scripts/chat-regression-v3.mjs",
    "orders:status-audit": "node scripts/order-status-write-audit.mjs",
    "types:mirror-audit": "node scripts/type-mirror-audit.mjs",
    "templates:mirror-audit": "node scripts/templates-mirror-audit.mjs",
    "showcase:route-audit": "node scripts/showcase-route-audit.mjs",
    "v2:deploy-audit": "node scripts/v2-deploy-script-audit.mjs",
    "v2:type-safety-audit": "node scripts/v2-type-safety-audit.mjs",
    "v2:edge-security-audit": "node scripts/v2-edge-security-audit.mjs",
    "v2:deno-check": "npx -y deno@2.8.2 check --import-map=supabase/functions/import_map.json supabase/functions/chat-orchestrator/index.ts supabase/functions/fact-extractor/index.ts supabase/functions/admin-order-action/index.ts supabase/functions/referrer-order/index.ts supabase/functions/lab-ingest/index.ts supabase/functions/lab-confirm/index.ts supabase/functions/wearable-ingest/index.ts supabase/functions/line-webhook/index.ts supabase/functions/stripe-checkout/index.ts supabase/functions/stripe-webhook/index.ts supabase/functions/pdpa-export/index.ts supabase/functions/pdpa-delete/index.ts",
    "v2:pdpa-coverage-audit": "node scripts/pdpa-coverage-audit.mjs",
    "v2:deno-test": "npx -y deno@2.8.2 test --allow-env --allow-net --import-map=supabase/functions/import_map.json supabase/functions/_shared/__tests__/",
    "v2:docs-audit": "node scripts/v2-docs-audit.mjs",
    "v2:e2e-commerce": "node scripts/e2e-commerce.mjs",
    "v2:external-preflight": "node scripts/v2-external-preflight.mjs",
    "v2:local-readiness-audit": "node scripts/v2-local-readiness-audit.mjs",
    "v2:open-questions-audit": "node scripts/v2-open-questions-audit.mjs",
    "v2:rls-check": "node scripts/rls-check.mjs",
    "v2:schema-audit": "node scripts/v2-schema-audit.mjs",
    "v2:health-safety-audit": "node scripts/v2-health-safety-audit.mjs",
    "v2:client-audit": "node scripts/v2-client-audit.mjs",
    "v2:verify": "npm run typecheck && npm run showcase:route-audit && npm run v2:type-safety-audit && npm run chat:quality && npm run orders:status-audit && npm run v2:schema-audit && npm run v2:open-questions-audit && npm run v2:local-readiness-audit && npm run v2:docs-audit && npm run v2:client-audit && npm run v2:edge-security-audit && npm run v2:health-safety-audit && npm run v2:pdpa-coverage-audit && npm run types:mirror-audit && npm run templates:mirror-audit && npm run v2:deploy-audit && npm run v2:deno-check && npm run v2:deno-test",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
