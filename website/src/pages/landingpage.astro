---
// The landing page now lives at "/". This route is kept as a permanent
// redirect so any existing /landingpage links continue to resolve.
const target = '/';
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mira</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
  </head>
  <body>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
    <p><a href={target}>ไปที่ Mira landing page</a></p>
  </body>
</html>
