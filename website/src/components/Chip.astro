---
interface Props {
  tone?: 'default' | 'brand' | 'mint' | 'amber' | 'rose' | 'dark';
}

const { tone = 'default' } = Astro.props;
---

<span class:list={['chip', `chip-${tone}`]}>
  <slot />
</span>

<style>
  .chip {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.78);
    color: var(--ink);
    font-family: "Space Grotesk", "Anuphan", sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0.45rem 0.78rem;
  }

  .chip-brand {
    border-color: rgba(46, 107, 246, 0.4);
    background: var(--brand-soft);
    color: var(--brand-deep);
  }

  .chip-mint {
    border-color: rgba(84, 207, 165, 0.45);
    background: rgba(84, 207, 165, 0.14);
    color: var(--mint-deep);
  }

  .chip-amber {
    border-color: rgba(245, 184, 75, 0.48);
    background: rgba(245, 184, 75, 0.16);
    color: #7A5200;
  }

  .chip-rose {
    border-color: rgba(229, 143, 162, 0.46);
    background: var(--rose-soft);
    color: var(--rose-deep);
  }

  .chip-dark {
    border-color: var(--night-line);
    background: rgba(214, 226, 255, 0.07);
    color: #EAF1FF;
  }
</style>
