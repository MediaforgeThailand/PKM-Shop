---
import MotionLoop from './MotionLoop.astro';
---

<section id="mirabeauty" class="vertical-panel beauty" data-vertical-panel>
  <div class="container vertical-inner">
    <figure class="vertical-visual" data-reveal>
      <MotionLoop name="mirabeauty" />
    </figure>

    <div class="vertical-copy" data-reveal>
      <span class="vertical-badge">MiraBeauty · สำหรับคลินิกความงาม</span>
      <h3>ที่ปรึกษาความงามที่ปิดการขายเก่งที่สุดของคลินิก</h3>
      <ul>
        <li>สแกนใบหน้า → คำแนะนำเฉพาะคน</li>
        <li>เสนอคอร์สถูกจังหวะ ตอนลูกค้าอินที่สุด</li>
        <li>ลูกค้าบอกต่อ รับส่วนแบ่งผ่าน Referral</li>
      </ul>
      <p class="vertical-claim">ตอนเห็นผลสแกนหน้าตัวเอง คือตอนที่อยากซื้อที่สุด — Mira เสนอคอร์สตรงนั้น</p>
      <a class="mini-cta" href="#contact">ดูเดโมเวอร์ชันคลินิก <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<style>
  .vertical-panel {
    position: relative;
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    overflow: clip;
  }

  .beauty {
    background:
      radial-gradient(circle at 88% 18%, rgba(229, 143, 162, 0.22), transparent 36%),
      linear-gradient(180deg, var(--rose-soft), var(--canvas));
  }

  .vertical-inner {
    display: grid;
    grid-template-columns: minmax(360px, 1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .vertical-badge {
    display: inline-flex;
    border-radius: var(--radius-pill);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    color: var(--rose-deep);
    font-weight: 600;
    padding: 0.45rem 0.8rem;
  }

  h3 {
    margin: 1.2rem 0 0;
    font-size: clamp(1.9rem, 4vw, 3.1rem);
    font-weight: 600;
    line-height: 1.14;
  }

  p {
    margin: 1rem 0 0;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .vertical-claim {
    border-left: 3px solid var(--rose);
    color: var(--ink);
    font-weight: 600;
    padding-left: 1rem;
  }

  ul {
    display: grid;
    gap: 0.8rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    padding-left: 1.3rem;
  }

  li::before {
    position: absolute;
    top: 0.72rem;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--rose);
    content: "";
  }

  .vertical-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(229, 143, 162, 0.28);
    border-radius: 30px;
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .vertical-inner {
      grid-template-columns: 1fr;
    }

    .vertical-visual {
      order: 2;
    }
  }
</style>
