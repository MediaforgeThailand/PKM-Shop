---
const links = [
  { href: '#ai-chat', label: 'AI Chat' },
  { href: '#admin', label: 'หลังบ้าน' },
  { href: '#referral', label: 'Referral' },
  { href: '#miracare', label: 'MiraCare' },
  { href: '#mirabeauty', label: 'MiraBeauty' },
  { href: '#contact', label: 'ติดต่อเรา' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <div>
      <a class="wordmark" href="#top" aria-label="mira AI home">
        <img
          class="wordmark-image"
          src="/mira-ai-wordmark.webp"
          alt="Mira AI"
          width="346"
          height="82"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p class="tagline">AI Chat ที่ขายเป็น × Referral ที่ขยายยอดขาย</p>
    </div>
    <p>© MediaForge</p>
    <nav aria-label="ท้ายหน้า">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--night-line);
    background: var(--night);
    color: var(--muted-dark);
    padding: 1.7rem 0 2.1rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    width: 120px;
    aspect-ratio: 346 / 82;
    color: #EAF1FF;
    line-height: 1;
  }

  .wordmark-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .tagline {
    margin: 0.45rem 0 0;
    font-size: 0.82rem;
  }

  p {
    margin: 0;
    font-size: 0.9rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.8rem 1.25rem;
    font-size: 0.9rem;
  }

  a {
    transition: color 180ms ease;
  }

  a:hover {
    color: #EAF1FF;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
