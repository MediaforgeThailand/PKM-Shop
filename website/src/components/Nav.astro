---
import Button from './Button.astro';

const links = [
  { href: '#ai-chat', label: 'AI Chat' },
  { href: '#admin', label: 'หลังบ้าน' },
  { href: '#referral', label: 'Referral' },
  { href: '#miracare', label: 'MiraCare' },
  { href: '#mirabeauty', label: 'MiraBeauty' },
  { href: '#contact', label: 'ติดต่อเรา' },
];
---

<header class="site-header" data-site-header>
  <nav class="nav container" aria-label="หลัก">
    <a class="wordmark" href="#top" aria-label="mira AI home">
      <span class="wordmark-orbit" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="16" r="6.5" fill="url(#mw-g)"></circle>
          <path d="M3.5 21.5C8 26.5 19 28.5 26 22.5" stroke="url(#mw-g)" stroke-width="2.4" stroke-linecap="round"></path>
          <path d="M28.5 10.5C24 5.5 13 3.5 6 9.5" stroke="url(#mw-g)" stroke-width="2.4" stroke-linecap="round"></path>
          <defs>
            <linearGradient id="mw-g" x1="2" y1="28" x2="30" y2="4" gradientUnits="userSpaceOnUse">
              <stop stop-color="#2E6BF6"></stop>
              <stop offset="1" stop-color="#9CC3FE"></stop>
            </linearGradient>
          </defs>
        </svg>
      </span>
      <span>mira <em>AI</em></span>
    </a>

    <div class="nav-links" aria-label="เมนูหลัก">
      {links.map((link) => <a href={link.href} data-spy-link>{link.label}</a>)}
    </div>

    <div class="nav-cta">
      <Button href="#contact">นัดดูเดโม</Button>
    </div>

    <button class="menu-toggle" type="button" aria-label="เปิดเมนู" aria-expanded="false" data-menu-toggle>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="mobile-menu" data-mobile-menu aria-hidden="true">
    <div class="mobile-menu-inner container">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <Button href="#contact">นัดดูเดโม</Button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    transition: background 220ms ease, border-color 220ms ease, backdrop-filter 220ms ease;
  }

  .site-header.is-scrolled,
  .site-header.is-open {
    border-bottom: 1px solid var(--night-line);
    background: rgba(5, 18, 38, 0.9);
    backdrop-filter: blur(18px);
  }

  .nav {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 78px;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    transition: min-height 220ms ease;
  }

  .site-header.is-scrolled .nav {
    min-height: 64px;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #EAF2FF;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1;
  }

  .wordmark em {
    color: var(--sky);
    font-style: normal;
  }

  .wordmark-orbit {
    display: inline-flex;
    width: 26px;
    height: 26px;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: clamp(0.9rem, 2.2vw, 1.8rem);
    color: var(--muted-dark);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .nav-links a {
    position: relative;
    padding: 0.3rem 0;
    transition: color 180ms ease;
  }

  .nav-links a::after {
    position: absolute;
    inset: auto 0 0;
    height: 2px;
    content: "";
    transform: scaleX(0);
    transform-origin: left;
    border-radius: 2px;
    background: var(--grad-brand);
    transition: transform 240ms var(--ease-out);
  }

  .nav-links a:hover,
  .nav-links a.is-active {
    color: #fff;
  }

  .nav-links a.is-active::after {
    transform: scaleX(1);
  }

  .nav-cta :global(.btn) {
    min-height: 42px;
    padding: 0.7rem 1.05rem;
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid var(--night-line);
    border-radius: 50%;
    background: rgba(214, 230, 255, 0.07);
    color: #EAF2FF;
  }

  .menu-toggle span {
    position: absolute;
    width: 18px;
    height: 2px;
    border-radius: 99px;
    background: currentColor;
    transition: transform 180ms ease;
  }

  .menu-toggle span:first-child {
    transform: translateY(-4px);
  }

  .menu-toggle span:last-child {
    transform: translateY(4px);
  }

  .site-header.is-open .menu-toggle span:first-child {
    transform: rotate(45deg);
  }

  .site-header.is-open .menu-toggle span:last-child {
    transform: rotate(-45deg);
  }

  .mobile-menu {
    display: none;
  }

  :global(html.menu-open),
  :global(html.menu-open body) {
    overflow: hidden;
  }

  @media (max-width: 820px) {
    .site-header.is-open {
      height: 100svh;
      overflow: hidden;
      background: var(--night);
    }

    .nav {
      min-height: 68px;
      grid-template-columns: auto 1fr auto;
    }

    .nav-links,
    .nav-cta {
      display: none;
    }

    .menu-toggle {
      display: grid;
      position: relative;
      justify-self: end;
    }

    .mobile-menu {
      position: absolute;
      inset: 68px 0 0;
      z-index: 1;
      display: block;
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 12%, rgba(46, 107, 246, 0.25), transparent 38%),
        linear-gradient(180deg, rgba(5, 18, 38, 0.98), var(--night) 58%);
      backdrop-filter: blur(18px);
      transition: opacity 180ms ease, visibility 180ms ease;
    }

    .site-header.is-open .mobile-menu {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
    }

    .mobile-menu-inner {
      display: grid;
      gap: 1rem;
      align-content: start;
      min-height: calc(100svh - 68px);
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .mobile-menu a:not(.btn) {
      border-bottom: 1px solid var(--night-line);
      color: #EAF2FF;
      font-size: 1.35rem;
      font-weight: 600;
      padding: 0.85rem 0;
    }
  }
</style>
