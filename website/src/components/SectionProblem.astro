---
import Section from './Section.astro';

const cards = [
  {
    key: 'time',
    title: 'ตอบไม่ทัน',
    body: 'ลูกค้าทักนอกเวลาทำการ ไม่มีคนตอบ ดีลค่อย ๆ เย็นลงเอง',
  },
  {
    key: 'scatter',
    title: 'lead กระจัดกระจาย',
    body: 'แชทอยู่หลายช่องทาง ไม่มีที่รวม ตกหล่นได้ง่าย',
  },
  {
    key: 'unknown',
    title: 'ไม่รู้ว่าใครพามา',
    body: 'การบอกต่อเกิดขึ้นจริง แต่วัดผลและให้รางวัลไม่ได้',
  },
];
---

<Section id="problem" tone="dark" class="problem-section">
  <header class="section-head problem-head">
    <span class="ghost-word" aria-hidden="true">PROBLEM</span>
    <p class="eyebrow" data-reveal>ปัญหาที่ทุกองค์กรเจอ</p>
    <h2 class="section-title" data-reveal>
      ลูกค้าทักเข้ามาทุกวัน<br />แต่ยอดขาย<span class="gradient-text">รั่วอยู่เงียบ ๆ</span>
    </h2>
  </header>

  <div class="problem-grid">
    {cards.map((card) => (
      <article class="problem-card glass-panel" data-reveal>
        <span class:list={['pc-scene', `pc-scene--${card.key}`]} aria-hidden="true">
          {card.key === 'time' && (
            <>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
                <circle cx="12" cy="12" r="8"></circle>
                <path d="M12 8v4l2.6 1.6"></path>
              </svg>
              <i class="pc-bubble"></i>
            </>
          )}
          {card.key === 'scatter' && (
            <svg viewBox="0 0 48 32" fill="currentColor" aria-hidden="true">
              <circle class="d d1" cx="8" cy="10" r="3"></circle>
              <circle class="d d2" cx="24" cy="6" r="3"></circle>
              <circle class="d d3" cx="40" cy="13" r="3"></circle>
              <circle class="d d4" cx="15" cy="24" r="3"></circle>
              <circle class="d d5" cx="34" cy="25" r="3"></circle>
            </svg>
          )}
          {card.key === 'unknown' && (
            <>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="3.4"></circle>
                <path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"></path>
              </svg>
              <b class="pc-q">?</b>
            </>
          )}
        </span>
        <h3>{card.title}</h3>
        <p>{card.body}</p>
      </article>
    ))}
  </div>
</Section>

<style>
  .problem-head {
    max-width: 820px;
  }

  .section-title :global(.gradient-text) {
    /* warm the leak headline toward the rose "loss" accent */
    background-image: linear-gradient(105deg, #E58FA2 0%, #F2B5C2 100%);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
    margin-top: clamp(2.2rem, 4vw, 3rem);
  }

  .problem-card {
    border-radius: var(--radius-lg);
    padding: clamp(1.4rem, 2.4vw, 1.8rem);
  }

  .problem-card h3 {
    margin: 1.1rem 0 0;
    font-size: clamp(1.2rem, 2.2vw, 1.45rem);
    font-weight: 600;
    color: #F2F7FF;
  }

  .problem-card p {
    margin: 0.5rem 0 0;
    color: var(--muted-dark);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* mini-scene tile */
  .pc-scene {
    position: relative;
    display: grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 16px;
    background: rgba(127, 177, 254, 0.12);
    border: 1px solid var(--night-line);
    color: var(--sky);
  }

  .pc-scene svg {
    width: 30px;
    height: 30px;
    overflow: visible;
  }

  .pc-scene--unknown,
  .pc-scene--time {
    color: var(--rose);
    background: rgba(229, 143, 162, 0.12);
  }

  /* card 1 — a chat message floats up and fades = lost lead */
  .pc-bubble {
    position: absolute;
    top: 8px;
    right: 6px;
    width: 12px;
    height: 9px;
    border-radius: 4px 4px 4px 1px;
    background: var(--rose);
    opacity: 0;
    animation: pcDrift 3.4s var(--ease-out) infinite;
  }

  @keyframes pcDrift {
    0% { opacity: 0; transform: translateY(6px) scale(0.7); }
    25% { opacity: 0.95; transform: translateY(0) scale(1); }
    70% { opacity: 0; transform: translateY(-14px) scale(0.85); }
    100% { opacity: 0; transform: translateY(-14px) scale(0.85); }
  }

  /* card 2 — scattered dots blink out of sync = fragmentation */
  .pc-scene--scatter .d {
    opacity: 0.35;
    animation: pcBlink 2.6s ease-in-out infinite;
  }
  .pc-scene--scatter .d2 { animation-delay: 0.5s; }
  .pc-scene--scatter .d3 { animation-delay: 1s; }
  .pc-scene--scatter .d4 { animation-delay: 1.5s; }
  .pc-scene--scatter .d5 { animation-delay: 0.8s; }

  @keyframes pcBlink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* card 3 — pulsing question mark = untracked referral */
  .pc-q {
    position: absolute;
    top: 4px;
    right: 8px;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: var(--rose);
    animation: pcPulse 2.2s ease-in-out infinite;
  }

  @keyframes pcPulse {
    0%, 100% { opacity: 0.4; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  @media (max-width: 880px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
