---
import Section from './Section.astro';
import MotionLoop from './MotionLoop.astro';

// The video carries the demo; this text is the SEO + screen-reader equivalent.
const channels = [
  'PWA — เปิดจากเบราว์เซอร์ ไม่ต้องติดตั้ง',
  'App — iOS / Android ในแบรนด์ของคุณ',
  'LINE OA — ใน LINE ที่ลูกค้าคุ้นที่สุด',
];
---

<Section id="channels" tone="light" class="channels-section">
  <header class="section-head">
    <span class="ghost-word" aria-hidden="true">CHANNELS</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">04</span>
      <span class="kicker-rule"></span>
      ONE BRAIN, EVERY CHANNEL
    </p>
    <h2 class="section-title" data-reveal>ลูกค้าอยู่ตรงไหน ก็คุยกับ <span class="gradient-text">Mira</span> ได้</h2>
    <p class="section-sub" data-reveal>เราปรับ Mira ให้เข้ากับแบรนด์และระบบของคุณ — ไม่ใช่ให้คุณปรับเข้าหาเรา</p>
  </header>

  <figure class="ch-video" data-reveal>
    <MotionLoop name="channels" />
    <figcaption class="sr-only">
      Mira สมองเดียว ตอบลูกค้าได้ทุกช่องทาง:
      <ul>
        {channels.map((channel) => <li>{channel}</li>)}
      </ul>
    </figcaption>
  </figure>

  <a class="mini-cta" href="#contact" data-reveal>คุยเรื่องการเชื่อมระบบของคุณ <span class="arrow">→</span></a>
</Section>

<style>
  .section-head {
    max-width: 860px;
  }

  .ch-video {
    position: relative;
    margin: clamp(1.8rem, 4vw, 2.8rem) 0 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--canvas);
    box-shadow: 0 40px 92px -46px rgba(46, 107, 246, 0.5);
  }

  .mini-cta {
    margin-top: 1.8rem;
  }
</style>
