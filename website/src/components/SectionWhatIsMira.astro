---
import Section from './Section.astro';

const pillars = [
  {
    label: 'AI Sales Chat',
    body: 'ตอบ แนะนำ เก็บ lead และส่งต่อทีมขาย',
  },
  {
    label: 'Referral Engine',
    body: 'track ผู้แนะนำ และตั้งค่า commission',
  },
  {
    label: 'Admin Dashboard',
    body: 'คุมสินค้า ราคา ออเดอร์ และยอดขาย',
  },
];
---

<Section id="what-is-mira" tone="light" class="wim-section">
  <header class="section-head wim-head">
    <span class="ghost-word" aria-hidden="true">WHAT IS MIRA</span>
    <p class="eyebrow" data-reveal>WHAT IS MIRA</p>
    <h2 class="section-title" data-reveal>
      ไม่ใช่ chatbot สำเร็จรูป<br />แต่เป็น<span class="gradient-text">ระบบขายที่ออกแบบให้องค์กรคุณ</span>
    </h2>
    <p class="section-sub" data-reveal>
      Mira รวม AI Sales Chat, Referral Engine และ Admin Dashboard ไว้ในระบบเดียว ทีมเราออกแบบ ติดตั้ง และเชื่อมกับข้อมูลจริงของคุณ แล้วส่งมอบเป็นระบบที่พร้อมขาย
    </p>
  </header>

  <div class="wim-map" data-reveal aria-hidden="true">
    <div class="wim-core">
      <span class="wim-core-mark">M</span>
      <span class="wim-core-text">Mira · <b>ระบบเดียว</b></span>
    </div>

    <svg class="wim-wires" viewBox="0 0 900 120" preserveAspectRatio="none">
      <path class="wire" d="M450 6 C 300 60, 150 50, 150 116" />
      <path class="wire" d="M450 6 C 450 70, 450 70, 450 116" />
      <path class="wire" d="M450 6 C 600 60, 750 50, 750 116" />
    </svg>

    <div class="wim-pillars">
      {pillars.map((pillar) => (
        <article class="wim-pillar">
          <span class="wim-dot" aria-hidden="true"></span>
          <strong>{pillar.label}</strong>
          <span>{pillar.body}</span>
        </article>
      ))}
    </div>
  </div>

  <p class="wim-foot" data-reveal>ออกแบบ · ติดตั้ง · เชื่อมข้อมูลจริง — ส่งมอบเป็นระบบที่พร้อมขาย</p>
</Section>

<style>
  .wim-head {
    max-width: 860px;
  }

  .wim-map {
    position: relative;
    margin-top: clamp(2.4rem, 5vw, 3.6rem);
  }

  /* central brain */
  .wim-core {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-inline: auto;
    padding: 0.6rem 1.2rem 0.6rem 0.6rem;
    border-radius: var(--radius-pill);
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    font-weight: 600;
    width: max-content;
  }

  .wim-core-mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--grad-brand);
    color: #fff;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 600;
  }

  .wim-core-text b {
    color: var(--brand);
  }

  /* converging wires */
  .wim-wires {
    position: relative;
    z-index: 0;
    display: block;
    width: 100%;
    height: clamp(70px, 8vw, 110px);
    margin-top: -6px;
  }

  .wire {
    fill: none;
    stroke: var(--brand);
    stroke-width: 2;
    stroke-dasharray: 6 9;
    stroke-linecap: round;
    opacity: 0.5;
    animation: wireFlow 1.4s linear infinite;
  }

  @keyframes wireFlow {
    to { stroke-dashoffset: -30; }
  }

  /* the three capabilities */
  .wim-pillars {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
    margin-top: -4px;
  }

  .wim-pillar {
    display: grid;
    gap: 0.35rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.2rem, 2.2vw, 1.6rem);
    text-align: center;
  }

  .wim-dot {
    justify-self: center;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--grad-brand);
    box-shadow: 0 0 0 5px rgba(46, 107, 246, 0.12);
  }

  .wim-pillar strong {
    margin-top: 0.5rem;
    font-family: "Space Grotesk", "Anuphan", sans-serif;
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    font-weight: 600;
    color: var(--ink);
  }

  .wim-pillar span {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .wim-foot {
    margin: clamp(1.6rem, 3vw, 2.2rem) 0 0;
    text-align: center;
    color: var(--ink-soft);
    font-weight: 600;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
  }

  @media (max-width: 880px) {
    .wim-wires {
      display: none;
    }

    .wim-pillars {
      grid-template-columns: 1fr;
      margin-top: 1.2rem;
    }
  }
</style>
