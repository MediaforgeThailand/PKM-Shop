---
import Button from './Button.astro';
import MotionLoop from './MotionLoop.astro';
---

<section id="top" class="hero section-dark grain">
  <div class="hero-media" aria-hidden="true">
    <MotionLoop name="hero-aurora" />
    <span class="hero-layer layer-a"></span>
    <span class="hero-layer layer-b"></span>
  </div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow hero-eyebrow" data-reveal>ENTERPRISE AI SALES PLATFORM</p>
      <h1 data-hero-title data-words>
        <span class="line"><span class="w">เปลี่ยน</span><span class="w">แชท</span><span class="w">ของ</span><span class="w">องค์กร</span></span>
        <span class="line line-2"><span class="w">ให้เป็น</span><span class="w gradient-text">ระบบขาย&nbsp;24&nbsp;ชั่วโมง</span></span>
      </h1>
      <p class="hero-sub" data-reveal>
        Mira คือ AI Sales Chat + Referral Engine ที่ออกแบบและติดตั้งให้เข้ากับข้อมูลสินค้า แบรนด์ และ workflow จริงขององค์กรคุณ
      </p>
      <ul class="hero-points" data-reveal>
        <li>AI ช่วยตอบ แนะนำ เก็บ lead และส่งต่อทีมขาย</li>
        <li>เชื่อมข้อมูลสินค้า ราคา โปรโมชัน และ FAQ จริงขององค์กร</li>
        <li>Referral Engine — track ผู้แนะนำ และตั้งค่า commission ได้เอง</li>
      </ul>
      <div class="button-row hero-actions" data-reveal>
        <Button href="#contact" magnetic>นัดดูเดโมสำหรับองค์กร</Button>
        <Button href="#what-is-mira" variant="ghost">ดู Flow การทำงาน ↓</Button>
      </div>
      <p class="hero-rotate" data-reveal aria-hidden="true">
        <span>จากแชทลูกค้า → lead</span>
        <span>จาก lead → order</span>
        <span>จากลูกค้าเก่า → referral</span>
        <span>จาก referral → ยอดขายที่วัดผลได้</span>
      </p>
    </div>
    <div class="hero-device" data-reveal>
      <MotionLoop name="hero-chat" class="hero-chat" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(96svh, 960px);
    padding: clamp(6.5rem, 10vw, 8.5rem) 0 0;
    overflow: clip;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 18%, rgba(46, 107, 246, 0.3), transparent 34%),
      radial-gradient(circle at 80% 10%, rgba(127, 177, 254, 0.16), transparent 30%),
      linear-gradient(180deg, var(--night), #082040 84%);
  }

  .hero-media :global(.motion-loop) {
    opacity: 0.85;
  }

  .hero-layer {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(60px);
  }

  .layer-a {
    top: -12%;
    left: -6%;
    width: 46vw;
    height: 46vw;
    background: radial-gradient(circle, rgba(46, 107, 246, 0.3), transparent 64%);
  }

  .layer-b {
    right: -8%;
    bottom: -18%;
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, rgba(23, 86, 219, 0.34), transparent 62%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(340px, 0.75fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  h1 {
    display: grid;
    gap: 0.45rem;
    max-width: 900px;
    margin: 1.2rem 0 0;
    color: #F2F7FF;
    font-size: clamp(2.5rem, 6.5vw, 5.25rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.1;
  }

  .line {
    display: block;
  }

  .line-2 {
    max-width: 880px;
    font-size: clamp(1.45rem, 3.2vw, 2.6rem);
    color: #C9DCFB;
  }

  :global(html.has-motion) [data-words] .w {
    opacity: 0;
    transform: translateY(44px);
    filter: blur(14px);
  }

  .w {
    display: inline-block;
    will-change: transform, opacity, filter;
  }

  .hero-sub {
    max-width: 640px;
    margin: 1.4rem 0 0;
    color: var(--muted-dark);
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
  }

  .hero-actions {
    margin-top: 1.9rem;
  }

  .hero-points {
    display: grid;
    gap: 0.65rem;
    max-width: 620px;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .hero-points li {
    position: relative;
    padding-left: 1.9rem;
    color: #C9DCFB;
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    line-height: 1.5;
  }

  .hero-points li::before {
    position: absolute;
    top: 0.18rem;
    left: 0;
    display: grid;
    width: 22px;
    height: 22px;
    place-items: center;
    border-radius: 50%;
    background: rgba(84, 207, 165, 0.16);
    color: var(--mint);
    content: "✓";
    font-size: 0.72rem;
    font-weight: 700;
  }

  .hero-rotate {
    position: relative;
    height: 1.7em;
    margin: 1.5rem 0 0;
    font-family: "Space Grotesk", "Anuphan", sans-serif;
    font-weight: 600;
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    color: var(--sky);
  }

  .hero-rotate span {
    position: absolute;
    inset: 0 auto auto 0;
    white-space: nowrap;
    opacity: 0;
    animation: heroRotate 12s var(--ease-out) infinite;
  }

  .hero-rotate span:nth-child(2) { animation-delay: 3s; }
  .hero-rotate span:nth-child(3) { animation-delay: 6s; }
  .hero-rotate span:nth-child(4) { animation-delay: 9s; }

  @keyframes heroRotate {
    0% { opacity: 0; transform: translateY(8px); }
    4% { opacity: 1; transform: translateY(0); }
    21% { opacity: 1; transform: translateY(0); }
    25% { opacity: 0; transform: translateY(-8px); }
    100% { opacity: 0; transform: translateY(-8px); }
  }

  .hero-device {
    position: relative;
    aspect-ratio: 880 / 1200;
    width: 100%;
    max-width: 440px;
    margin-inline: auto;
  }

  .hero-device :global(.motion-loop video) {
    object-fit: cover;
    /* dissolve the opaque video's top/bottom edges into the hero so it reads as
       floating chat, not a boxed panel (kept opaque so it autoplays everywhere) */
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 13%, #000 87%, transparent 100%);
    mask-image: linear-gradient(180deg, transparent 0%, #000 13%, #000 87%, transparent 100%);
  }

  .hero-device::before {
    position: absolute;
    inset: 10% 2% 2%;
    z-index: -1;
    content: "";
    border-radius: 44%;
    background: radial-gradient(circle, rgba(63, 142, 252, 0.4), transparent 66%);
    filter: blur(34px);
  }

  @media (max-width: 1020px) {
    .hero {
      min-height: auto;
      padding-top: 6.25rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-device {
      max-width: 460px;
      margin-inline: auto;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: clamp(2.15rem, 11vw, 2.9rem);
    }

    .line-2 {
      font-size: clamp(1.2rem, 6vw, 1.6rem);
    }

    .hero-sub {
      font-size: 0.98rem;
      line-height: 1.6;
    }
  }
</style>
