---
import Section from './Section.astro';
import MotionLoop from './MotionLoop.astro';

// The video carries the full story; this text is the SEO + screen-reader equivalent.
const steps = [
  'ตั้งค่าสินค้า ราคา และค่าคอมมิชชั่นได้เอง',
  'ให้ AI แนะนำข้อมูลสินค้าและข้อความปิดการขาย',
  'สร้าง QR ราคาตามสินค้า แล้วติดตามสถานะการชำระเงิน',
  'ยืนยันคิวออเดอร์ของลูกค้า และดูแดชบอร์ดยอดขาย + คอมมิชชั่น',
];
---

<Section id="admin" tone="light" class="admin-section">
  <header class="section-head admin-head">
    <span class="ghost-word" aria-hidden="true">BACK OFFICE</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">03</span>
      <span class="kicker-rule"></span>
      ADMIN DASHBOARD
    </p>
    <h2 class="section-title" data-reveal>
      คุมทุกอย่างจากที่เดียว — <span class="gradient-text">สินค้า ราคา ออเดอร์ และยอดขาย</span>
    </h2>
    <p class="section-sub" data-reveal>
      ทีมคุณแก้สินค้า ตั้งราคา ตั้ง commission ยืนยันออเดอร์ และดู performance ได้เอง ทุกการเปลี่ยนแปลง Mira รู้ทันที
    </p>
  </header>

  <figure class="bo-video" data-reveal>
    <MotionLoop name="back-office" />
    <figcaption class="sr-only">
      ระบบหลังบ้าน Mira จัดการได้ในที่เดียว:
      <ol>
        {steps.map((step) => <li>{step}</li>)}
      </ol>
    </figcaption>
  </figure>
</Section>

<style>
  .admin-head {
    max-width: 860px;
  }

  .bo-video {
    /* ~10% safe zone each side; staying below the 1920px source keeps it crisp */
    position: relative;
    width: 80vw;
    margin: clamp(2rem, 4vw, 3rem) calc(50% - 40vw) 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: clamp(16px, 1.6vw, 28px);
    background: var(--canvas);
    box-shadow: 0 40px 92px -46px rgba(46, 107, 246, 0.5);
  }

  @media (max-width: 720px) {
    .bo-video {
      width: 92vw;
      margin: 0 calc(50% - 46vw);
    }
  }
</style>
