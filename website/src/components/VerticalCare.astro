---
import Chip from './Chip.astro';
import MotionLoop from './MotionLoop.astro';
---

<section id="miracare" class="vertical-panel care" data-vertical-panel>
  <div class="container vertical-inner">
    <div class="vertical-copy" data-reveal>
      <span class="vertical-badge">MiraCare · สำหรับโรงพยาบาล</span>
      <h3>Mira เวอร์ชันที่พูดภาษาโรงพยาบาล</h3>
      <ul>
        <li>ขายแพ็กเกจตรวจสุขภาพ พร้อมนัดหมายในแชท</li>
        <li>Referral สำหรับเครือข่ายหมอและพาร์ตเนอร์</li>
        <li>Health Dashboard <Chip tone="mint">ADD-ON</Chip> — ดึงคนไข้กลับมาตรวจรอบถัดไป</li>
      </ul>
      <p class="vertical-claim">ยอดรอบใหม่มาจากคนไข้เดิม — ระบบชวนกลับมาเอง</p>
      <a class="mini-cta" href="#contact">ดูเดโมเวอร์ชันโรงพยาบาล <span class="arrow">→</span></a>
    </div>

    <figure class="vertical-visual" data-reveal>
      <MotionLoop name="miracare" />
    </figure>
  </div>
</section>

<style>
  .vertical-panel {
    position: relative;
    padding: clamp(4rem, 7vw, 6.5rem) 0;
    overflow: clip;
  }

  .care {
    background:
      radial-gradient(circle at 8% 18%, rgba(14, 165, 164, 0.16), transparent 34%),
      linear-gradient(180deg, var(--canvas), var(--teal-soft));
  }

  .vertical-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .vertical-badge {
    display: inline-flex;
    border-radius: var(--radius-pill);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    color: #087B7A;
    font-weight: 600;
    padding: 0.45rem 0.8rem;
  }

  h3 {
    margin: 1.2rem 0 0;
    font-size: clamp(1.9rem, 4vw, 3.1rem);
    font-weight: 600;
    line-height: 1.14;
  }

  p {
    margin: 1rem 0 0;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .vertical-claim {
    border-left: 3px solid var(--teal);
    color: var(--ink);
    font-weight: 600;
    padding-left: 1rem;
  }

  ul {
    display: grid;
    gap: 0.8rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    padding-left: 1.3rem;
  }

  li::before {
    position: absolute;
    top: 0.72rem;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
    content: "";
  }

  li :global(.chip) {
    min-height: 26px;
    margin-inline: 0.25rem;
    padding: 0.2rem 0.52rem;
  }

  .vertical-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(14, 165, 164, 0.22);
    border-radius: 30px;
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .vertical-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
