---
interface Props {
  name: 'hero-aurora' | 'referral-flywheel' | 'miracare-pulse' | 'mirabeauty-scan' | 'ai-chat-story';
  class?: string;
}

const { name, class: className = '' } = Astro.props;
const base = `/motion/${name}`;
---

<div class:list={['motion-loop', className]} data-motion-shell>
  <video
    aria-hidden="true"
    muted
    loop
    playsinline
    preload="metadata"
    poster={`${base}.jpg`}
    data-motion-video
  >
    <source data-src={`${base}.webm`} type="video/webm" />
    <source data-src={`${base}.mp4`} type="video/mp4" />
  </video>
</div>
