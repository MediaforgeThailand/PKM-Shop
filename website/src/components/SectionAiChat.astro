---
import Section from './Section.astro';
import MotionLoop from './MotionLoop.astro';

// Spoken by the video; mirrored here as text for SEO + screen readers.
const steps = [
  'แนะนำตรงใจ — อ่านใจลูกค้าจากแชท แล้วเสนอของที่ใช่ โอกาสปิดสูงขึ้น',
  'ปิดการขายในแชท — เลือกของ จ่าย QR จบในแชทเดียว ไม่มีจังหวะให้เปลี่ยนใจ',
  'ข้อมูลคุณ คุมเองได้ — แก้สินค้า เปลี่ยนราคาเมื่อไหร่ AI รู้ทันที',
];
---

<Section id="ai-chat" tone="light" class="ai-chat-section">
  <header class="section-head">
    <span class="ghost-word" aria-hidden="true">AI CHAT</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">01</span>
      <span class="kicker-rule"></span>
      AI SALES CHAT
    </p>
    <p class="pain-line" data-reveal>ลูกค้าทักตอนตี 2 ไม่มีใครตอบ — ยอดนั้นหายไปเงียบ ๆ</p>
    <h2 class="section-title" data-reveal>
      Mira ตอบใน 1 วินาที <span class="gradient-text">และขายจนจบ</span>
    </h2>
  </header>

  <figure class="story-video" data-reveal>
    <MotionLoop name="ai-chat-story" />
    <figcaption class="sr-only">
      Mira ทำงานใน 3 ขั้น:
      <ol>
        {steps.map((step) => <li>{step}</li>)}
      </ol>
    </figcaption>
  </figure>
</Section>

<style>
  .section-head {
    max-width: 880px;
  }

  .story-video {
    position: relative;
    margin: clamp(1.8rem, 4vw, 2.8rem) 0 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--canvas);
    box-shadow: 0 44px 100px -48px rgba(46, 107, 246, 0.7);
  }
</style>
