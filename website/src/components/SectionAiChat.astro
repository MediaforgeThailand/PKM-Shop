---
import Section from './Section.astro';
import MotionLoop from './MotionLoop.astro';

// Spoken by the video; mirrored here as text for SEO + screen readers.
const steps = [
  'แนะนำตรงจากข้อมูลที่ลูกค้าบอกและข้อมูลสินค้าจริง — เพิ่มโอกาสปิด',
  'พาไปถึงการซื้อในแชท — เลือกของ จ่าย QR จบในที่เดียว',
  'ข้อมูลคุณคุมเองได้ — แก้สินค้า เปลี่ยนราคาเมื่อไหร่ Mira รู้ทันที',
];
---

<Section id="ai-chat" tone="light" class="ai-chat-section">
  <header class="section-head">
    <span class="ghost-word" aria-hidden="true">AI CHAT</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">01</span>
      <span class="kicker-rule"></span>
      AI SALES CHAT
    </p>
    <h2 class="section-title" data-reveal>
      ตอบเร็ว แนะนำตรง <span class="gradient-text">ไม่ปล่อย lead หลุด</span>
    </h2>
    <p class="section-sub" data-reveal>
      Mira ตอบลูกค้าได้ทันทีตลอด 24 ชั่วโมง แนะนำจากข้อมูลที่ลูกค้าบอกและข้อมูลสินค้าจริง เก็บ lead และส่งต่อให้ทีมขายเมื่อถึงจังหวะที่ต้องใช้คน
    </p>
  </header>

  <figure class="story-video" data-reveal>
    <MotionLoop name="ai-chat-story" />
    <figcaption class="sr-only">
      Mira ทำงานใน 3 ขั้น:
      <ol>
        {steps.map((step) => <li>{step}</li>)}
      </ol>
    </figcaption>
  </figure>
</Section>

<style>
  .section-head {
    max-width: 880px;
  }

  .story-video {
    position: relative;
    margin: clamp(1.8rem, 4vw, 2.8rem) 0 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--canvas);
    box-shadow: 0 44px 100px -48px rgba(46, 107, 246, 0.7);
  }
</style>
