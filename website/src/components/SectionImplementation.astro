---
import Section from './Section.astro';

const inputs = ['สินค้า', 'ราคา', 'โปรโมชัน', 'สาขา', 'FAQ'];

const cards = [
  {
    no: '01',
    en: 'Data Integration',
    body: 'เชื่อมสินค้า ราคา โปรโมชัน และ FAQ จริงขององค์กร',
  },
  {
    no: '02',
    en: 'Sales & Chat Flow',
    body: 'ออกแบบบทสนทนาและเส้นทางที่พาลูกค้าไปถึงการซื้อ',
  },
  {
    no: '03',
    en: 'Brand & CI',
    body: 'หน้าตาและน้ำเสียงของ Mira ตรงกับแบรนด์คุณ',
  },
  {
    no: '04',
    en: 'Back-office Setup',
    body: 'ตั้งค่าหลังบ้าน ทดสอบ และส่งมอบให้พร้อมใช้',
  },
];
---

<Section id="implementation" tone="surface" class="impl-section">
  <header class="section-head impl-head">
    <span class="ghost-word" aria-hidden="true">IMPLEMENT</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">06</span>
      <span class="kicker-rule"></span>
      ENTERPRISE IMPLEMENTATION
    </p>
    <h2 class="section-title" data-reveal>
      ทีมเราออกแบบและติดตั้งให้<br /><span class="gradient-text">ไม่ใช่ปล่อยให้คุณไปตั้งเอง</span>
    </h2>
    <p class="section-sub" data-reveal>
      เราเชื่อม Mira เข้ากับสินค้า ราคา โปรโมชัน สาขา และเงื่อนไขการขายจริงของคุณ ออกแบบ flow การคุยและ CI ให้ตรงแบรนด์ แล้วส่งมอบเป็นระบบที่ใช้งานได้ทันที
    </p>
  </header>

  <div class="impl-flow" data-reveal aria-hidden="true">
    <div class="impl-inputs">
      {inputs.map((input, index) => (
        <span class="impl-chip" style={`--i:${index}`}>{input}</span>
      ))}
    </div>
    <span class="impl-arrow">
      <svg viewBox="0 0 40 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12h28M24 5l8 7-8 7"></path>
      </svg>
    </span>
    <div class="impl-mira">
      <span class="impl-mira-mark">M</span>
      <span>Mira ของคุณ</span>
    </div>
  </div>

  <div class="impl-grid">
    {cards.map((card) => (
      <article class="impl-card" data-reveal>
        <span class="impl-no display-accent">{card.no}</span>
        <strong>{card.en}</strong>
        <p>{card.body}</p>
      </article>
    ))}
  </div>

  <a class="mini-cta" href="#contact" data-reveal>ดูระบบที่ออกแบบสำหรับองค์กร <span class="arrow">→</span></a>
</Section>

<style>
  .impl-head {
    max-width: 880px;
  }

  /* data inflow strip */
  .impl-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(0.8rem, 2vw, 1.4rem);
    margin-top: clamp(2.2rem, 4vw, 3rem);
    padding: clamp(1rem, 2.2vw, 1.5rem);
    border-radius: var(--radius-lg);
    background: var(--brand-wash);
    border: 1px solid var(--line);
  }

  .impl-inputs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .impl-chip {
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.92rem;
    font-weight: 500;
    animation: chipIn 3.6s var(--ease-out) infinite;
    animation-delay: calc(var(--i) * 0.4s);
  }

  @keyframes chipIn {
    0%, 70%, 100% { transform: translateX(0); opacity: 1; }
    82% { transform: translateX(6px); opacity: 0.55; }
  }

  .impl-arrow {
    color: var(--brand);
    flex: none;
  }

  .impl-arrow svg {
    width: 38px;
    height: 22px;
  }

  .impl-mira {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
    padding: 0.55rem 1.1rem 0.55rem 0.55rem;
    border-radius: var(--radius-pill);
    background: var(--grad-brand);
    color: #fff;
    font-weight: 600;
    box-shadow: var(--shadow-glow);
  }

  .impl-mira-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    font-family: "Space Grotesk", sans-serif;
  }

  /* 4 implementation cards */
  .impl-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 1.8vw, 1.3rem);
    margin-top: clamp(1.4rem, 2.6vw, 1.8rem);
  }

  .impl-card {
    position: relative;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
    padding: clamp(1.3rem, 2.2vw, 1.7rem);
    overflow: hidden;
  }

  .impl-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: var(--grad-brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 600ms var(--ease-out);
  }

  .impl-card[data-reveal-done]::before {
    transform: scaleX(1);
  }

  .impl-no {
    color: var(--brand);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .impl-card strong {
    display: block;
    margin-top: 0.55rem;
    font-family: "Space Grotesk", "Anuphan", sans-serif;
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--ink);
  }

  .impl-card p {
    margin: 0.4rem 0 0;
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .impl-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .impl-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
