---
import Section from './Section.astro';

const steps = [
  {
    no: '1',
    title: 'เข้าใจธุรกิจ',
    body: 'สินค้า ลูกค้า และเป้าหมายการขายของคุณ',
  },
  {
    no: '2',
    title: 'ออกแบบ + เชื่อมข้อมูล',
    body: 'flow การคุย, CI และข้อมูลจริงขององค์กร',
  },
  {
    no: '3',
    title: 'ติดตั้ง + เทรนทีม',
    body: 'ส่งมอบระบบ และสอนทีมคุณใช้งาน',
  },
  {
    no: '4',
    title: 'ใช้งานจริง + ปรับต่อเนื่อง',
    body: 'ดู performance แล้วปรับให้ดีขึ้นเรื่อย ๆ',
  },
];
---

<Section id="process" tone="light" class="process-section">
  <header class="section-head process-head">
    <span class="ghost-word" aria-hidden="true">PROCESS</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">07</span>
      <span class="kicker-rule"></span>
      HOW WE WORK
    </p>
    <h2 class="section-title" data-reveal>
      จากคุยครั้งแรก<br />ถึง<span class="gradient-text">ระบบที่พร้อมขาย</span>
    </h2>
  </header>

  <ol class="proc-steps">
    {steps.map((step) => (
      <li class="proc-step" data-reveal>
        <span class="proc-node display-accent" aria-hidden="true">{step.no}</span>
        <h3>{step.title}</h3>
        <p>{step.body}</p>
      </li>
    ))}
  </ol>
</Section>

<style>
  .process-head {
    max-width: 820px;
  }

  .proc-steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    margin: clamp(2.4rem, 4.5vw, 3.4rem) 0 0;
    padding: 0;
    list-style: none;
  }

  /* the connecting rail behind the nodes */
  .proc-steps::before {
    content: "";
    position: absolute;
    top: 27px;
    left: 8%;
    right: 8%;
    height: 2px;
    background: linear-gradient(90deg, var(--brand), var(--sky));
    opacity: 0.4;
  }

  .proc-step {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: start;
    gap: 0.3rem;
  }

  .proc-node {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--brand);
    color: var(--brand);
    font-size: 1.4rem;
    box-shadow: var(--shadow-soft);
  }

  .proc-step h3 {
    margin: 0.7rem 0 0;
    font-size: clamp(1.1rem, 2vw, 1.32rem);
    font-weight: 600;
    color: var(--ink);
  }

  .proc-step p {
    margin: 0.25rem 0 0;
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  @media (max-width: 880px) {
    .proc-steps {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* vertical rail on mobile */
    .proc-steps::before {
      top: 0;
      bottom: 0;
      left: 26px;
      right: auto;
      width: 2px;
      height: auto;
    }

    .proc-step {
      grid-template-columns: 54px 1fr;
      align-items: center;
      column-gap: 1rem;
      padding: 0.8rem 0;
    }

    .proc-node {
      grid-row: span 2;
    }

    .proc-step h3 {
      margin: 0;
      align-self: end;
    }

    .proc-step p {
      align-self: start;
    }
  }
</style>
