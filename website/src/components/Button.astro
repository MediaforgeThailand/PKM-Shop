---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost' | 'light';
  label?: string;
  magnetic?: boolean;
}

const { href, variant = 'primary', label, magnetic = false } = Astro.props;
---

<a class:list={['btn', `btn-${variant}`]} href={href} aria-label={label} data-magnetic={magnetic ? '' : undefined}>
  <span class="btn-label"><slot /></span>
</a>

<style>
  .btn {
    position: relative;
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    font-weight: 600;
    line-height: 1.2;
    padding: 0.85rem 1.5rem;
    overflow: hidden;
    transition: transform 200ms var(--ease-out), border-color 200ms ease, box-shadow 250ms ease;
    white-space: nowrap;
  }

  .btn-label {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: var(--grad-brand);
    box-shadow: var(--shadow-glow);
    color: #fff;
  }

  .btn-primary::before {
    position: absolute;
    inset: 0;
    content: "";
    transform: translateX(-110%) skewX(-16deg);
    background: linear-gradient(100deg, transparent 20%, rgba(255, 255, 255, 0.34) 50%, transparent 80%);
    transition: transform 700ms var(--ease-out);
  }

  .btn-primary:hover::before {
    transform: translateX(110%) skewX(-16deg);
  }

  .btn-primary:hover {
    box-shadow: 0 30px 70px -22px var(--glow-brand);
  }

  .btn-ghost {
    border: 1px solid var(--night-line);
    background: rgba(214, 226, 255, 0.05);
    color: #EAF1FF;
  }

  .btn-ghost:hover {
    border-color: rgba(147, 187, 254, 0.5);
  }

  .btn-light {
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    box-shadow: var(--shadow-soft);
  }

  @media (max-width: 480px) {
    .btn {
      width: 100%;
      white-space: normal;
    }
  }
</style>
