---
import Section from './Section.astro';

const faqs = [
  {
    q: 'Mira ต่างจาก chatbot ทั่วไปยังไง?',
    a: 'chatbot ทั่วไปตอบตาม script สำเร็จรูป ส่วน Mira ถูกออกแบบและเชื่อมกับข้อมูลขายจริงขององค์กรคุณ และพาลูกค้าไปถึงการซื้อหรือนัดหมาย',
  },
  {
    q: 'เป็นค่าบริการรายเดือนแบบ SaaS ไหม?',
    a: 'ไม่ใช่แพ็กเกจสำเร็จรูป Mira เป็น solution ที่ออกแบบตามขอบเขตของแต่ละองค์กร เราคุยรายละเอียดและประเมินให้หลังดูเดโม',
  },
  {
    q: 'ต้องเตรียมข้อมูลอะไรบ้าง?',
    a: 'ข้อมูลสินค้า ราคา โปรโมชัน สาขา และ FAQ เท่าที่มี ส่วนที่เหลือทีมเราช่วยจัดระเบียบและเชื่อมให้',
  },
  {
    q: 'ใช้เวลา implement นานแค่ไหน?',
    a: 'ขึ้นกับขอบเขตและความพร้อมของข้อมูล เราวางไทม์ไลน์ที่ชัดเจนให้ตั้งแต่ช่วงออกแบบ',
  },
  {
    q: 'AI จะมาแทนทีมขายเลยไหม?',
    a: 'ไม่ Mira ช่วยทีมขายตอบเร็วขึ้นและไม่ปล่อย lead หลุด งานที่ต้องใช้คน ระบบจะส่งต่อให้ทีมของคุณ',
  },
  {
    q: 'Referral track ยังไง และกันการสวมสิทธิ์ได้ไหม?',
    a: 'ผู้แนะนำแต่ละคนมีลิงก์และ QR เฉพาะตัว ระบบผูกเครดิตตั้งแต่ลูกค้าเข้ามา และบันทึกทุกออเดอร์ให้ตรวจสอบย้อนได้',
  },
  {
    q: 'เชื่อมกับระบบเดิม เช่น CRM หรือ POS ได้ไหม?',
    a: 'พิจารณาเป็นรายองค์กรในช่วงออกแบบ บอกระบบที่ใช้อยู่มา เราประเมินแนวทางเชื่อมต่อให้',
  },
  {
    q: 'ข้อมูลลูกค้าเป็นของใคร และปลอดภัยแค่ไหน?',
    a: 'ข้อมูลเป็นขององค์กรคุณ เราออกแบบการจัดเก็บและสิทธิ์การเข้าถึงตามมาตรฐานความปลอดภัย',
  },
];
---

<Section id="faq" tone="surface" class="faq-section">
  <header class="section-head faq-head">
    <span class="ghost-word" aria-hidden="true">FAQ</span>
    <p class="eyebrow" data-reveal>คำถามที่พบบ่อย</p>
    <h2 class="section-title" data-reveal>เรื่องที่องค์กร<span class="gradient-text">มักถามก่อนเริ่ม</span></h2>
  </header>

  <div class="faq-list">
    {faqs.map((item) => (
      <details class="faq-item" data-reveal>
        <summary>
          <span>{item.q}</span>
          <span class="faq-mark" aria-hidden="true"></span>
        </summary>
        <p>{item.a}</p>
      </details>
    ))}
  </div>
</Section>

<style>
  .faq-head {
    max-width: 760px;
  }

  .faq-list {
    display: grid;
    gap: 0.8rem;
    max-width: 860px;
    margin: clamp(2.2rem, 4vw, 3rem) auto 0;
  }

  .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--canvas);
    padding: 0 clamp(1.1rem, 2vw, 1.5rem);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .faq-item[open] {
    border-color: rgba(46, 107, 246, 0.4);
    box-shadow: var(--shadow-soft);
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.3rem) 0;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: clamp(1.02rem, 1.7vw, 1.15rem);
    color: var(--ink);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .faq-mark {
    position: relative;
    flex: none;
    width: 22px;
    height: 22px;
  }

  .faq-mark::before,
  .faq-mark::after {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 13px;
    height: 2px;
    border-radius: 2px;
    background: var(--brand);
    content: "";
    transform: translate(-50%, -50%);
    transition: transform 220ms var(--ease-out), opacity 220ms ease;
  }

  .faq-mark::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-item[open] .faq-mark::after {
    transform: translate(-50%, -50%) rotate(0deg);
    opacity: 0;
  }

  .faq-item p {
    margin: 0;
    padding: 0 0 clamp(1rem, 2vw, 1.3rem);
    max-width: 70ch;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
