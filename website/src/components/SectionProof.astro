---
import Section from './Section.astro';

const points = [
  {
    title: 'ติดตั้งกับธุรกิจจริง',
    body: 'Mira พัฒนาจากการวางระบบให้องค์กรที่ใช้ขายจริง ไม่ใช่เดโมในห้องแล็บ',
  },
  {
    title: 'Referral คือช่องทางที่โตเร็ว',
    body: 'จุดที่เราเห็นผลชัดที่สุด คือยอดจากการบอกต่อ เมื่อมีระบบ track และให้รางวัลโปร่งใส',
  },
  {
    title: 'ทุกยอดวัดผลได้',
    body: 'lead, order, referral และยอดขาย เห็นรวมกันในที่เดียว ตรวจสอบย้อนได้',
  },
];
---

<Section id="proof" tone="dark" class="proof-section">
  <div class="proof-spark" aria-hidden="true">
    <svg viewBox="0 0 200 80" preserveAspectRatio="none">
      <path class="proof-line" d="M0 70 C 40 64, 70 52, 100 40 S 160 14, 200 6" />
    </svg>
  </div>

  <header class="section-head proof-head">
    <span class="ghost-word" aria-hidden="true">PROOF</span>
    <p class="kicker" data-reveal>
      <span class="kicker-num">05</span>
      <span class="kicker-rule"></span>
      BUILT FROM REAL SALES DATA
    </p>
    <h2 class="section-title" data-reveal>
      สร้างจากระบบที่ใช้ขายจริง<br /><span class="gradient-text">ไม่ใช่เดโมสวย ๆ</span>
    </h2>
  </header>

  <div class="proof-grid">
    {points.map((point, index) => (
      <article class="proof-card glass-panel" data-reveal>
        <span class="proof-no display-accent" aria-hidden="true">0{index + 1}</span>
        <h3>{point.title}</h3>
        <p>{point.body}</p>
      </article>
    ))}
  </div>
</Section>

<style>
  .proof-section {
    position: relative;
  }

  /* faint upward trend behind the heading — implies growth, no numbers claimed */
  .proof-spark {
    position: absolute;
    inset: 0 0 auto auto;
    z-index: 0;
    width: min(46%, 540px);
    height: clamp(120px, 18vw, 230px);
    opacity: 0.5;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 60%);
    mask-image: linear-gradient(90deg, transparent, #000 60%);
  }

  .proof-spark svg {
    width: 100%;
    height: 100%;
  }

  .proof-line {
    fill: none;
    stroke: var(--sky);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: proofDraw 2.6s var(--ease-out) forwards;
  }

  @keyframes proofDraw {
    to { stroke-dashoffset: 0; }
  }

  .proof-head {
    max-width: 820px;
  }

  .proof-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
    margin-top: clamp(2.2rem, 4vw, 3rem);
  }

  .proof-card {
    border-radius: var(--radius-lg);
    padding: clamp(1.4rem, 2.4vw, 1.9rem);
  }

  .proof-no {
    color: var(--sky);
    font-size: 1.05rem;
    letter-spacing: 0.06em;
  }

  .proof-card h3 {
    margin: 0.7rem 0 0;
    font-size: clamp(1.15rem, 2.1vw, 1.4rem);
    font-weight: 600;
    color: #F2F7FF;
  }

  .proof-card p {
    margin: 0.55rem 0 0;
    color: var(--muted-dark);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  @media (max-width: 880px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
