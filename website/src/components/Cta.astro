---
import MotionLoop from './MotionLoop.astro';
---

<section id="contact" class="cta-section section-dark grain" data-spotlight>
  <div class="cta-media" aria-hidden="true">
    <MotionLoop name="hero-aurora" />
  </div>
  <div class="cta-spot" aria-hidden="true"></div>
  <div class="container cta-inner">
    <div class="cta-copy" data-reveal>
      <p class="kicker">
        <span class="kicker-num">05</span>
        <span class="kicker-rule"></span>
        FREE LIVE DEMO
      </p>
      <h2 class="section-title">อยากเห็น Mira <span class="gradient-text">ขายให้คุณ</span>?</h2>
      <p class="section-sub">เดโมสด 30 นาที ด้วยข้อมูลธุรกิจแบบคุณ — ไม่มีค่าใช้จ่าย</p>
      <figure class="cta-recap-video" data-reveal>
        <MotionLoop name="cta-recap" />
        <figcaption class="sr-only">
          <ul>
            <li>ฝั่งลูกค้า: แชท → จ่ายเงินจริง</li>
            <li>ฝั่งทีมคุณ: หลังบ้านทั้งชุด</li>
            <li>Referral ตั้งแต่แชร์ลิงก์ จนส่วนแบ่งเข้า</li>
          </ul>
        </figcaption>
      </figure>
    </div>

    <form class="contact-form glass-panel" data-contact-form data-mailto="taksin.taeprasert@gmail.com">
      {/* Web3Forms auto-delivery → taksin.taeprasert@gmail.com. Get a free key at https://web3forms.com (enter that address), then paste it below. */}
      <input type="hidden" name="access_key" value="REPLACE_WITH_WEB3FORMS_ACCESS_KEY" />
      <input type="hidden" name="subject" value="Mira — คำขอนัดเดโมฟรี" />
      <input type="hidden" name="from_name" value="Mira Landing Page" />
      <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />
      <label>
        <span>ชื่อ</span>
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        <span>องค์กร</span>
        <input name="organization" autocomplete="organization" required />
      </label>
      <label>
        <span>อีเมล</span>
        <input type="email" name="email" autocomplete="email" inputmode="email" placeholder="you@email.com" required />
      </label>
      <label>
        <span>เบอร์ติดต่อ</span>
        <input type="tel" name="phone" autocomplete="tel" inputmode="tel" placeholder="08x-xxx-xxxx" required />
      </label>
      <label>
        <span>ประเภทธุรกิจ</span>
        <select name="businessType" required>
          <option value="">เลือกประเภท</option>
          <option>โรงพยาบาล</option>
          <option>คลินิกความงาม</option>
          <option>อื่น ๆ</option>
        </select>
      </label>
      <button type="submit" data-magnetic>ส่งคำขอนัดเดโมฟรี</button>
      <p class="form-foot">ตอบกลับภายใน 1 วันทำการ</p>
      <p class="form-note" data-form-note hidden>เปิดแอปอีเมลของคุณแล้ว — ถ้าไม่ขึ้น ส่งตรงได้ที่ taksin.taeprasert@gmail.com</p>
    </form>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: clamp(4.5rem, 8vw, 7rem) 0;
    overflow: clip;
  }

  .cta-media {
    position: absolute;
    inset: 0;
    opacity: 0.3;
  }

  .cta-spot {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(560px circle at var(--mx, 70%) var(--my, 30%), rgba(46, 107, 246, 0.22), transparent 60%);
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.7fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .section-title {
    max-width: 780px;
  }

  .cta-ticks {
    display: grid;
    gap: 0.7rem;
    margin: 1.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .cta-ticks li {
    position: relative;
    color: var(--muted-dark);
    padding-left: 1.9rem;
  }

  .cta-ticks li::before {
    position: absolute;
    top: 0.18rem;
    left: 0;
    display: grid;
    width: 20px;
    height: 20px;
    place-items: center;
    border-radius: 50%;
    background: rgba(84, 207, 165, 0.16);
    color: var(--mint);
    content: "✓";
    font-size: 0.7rem;
    font-weight: 700;
  }

  .cta-recap-video {
    position: relative;
    margin: 1.6rem 0 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--night-line);
    border-radius: 22px;
    background: var(--night);
    box-shadow: 0 30px 70px -40px rgba(46, 107, 246, 0.55);
  }

  .contact-form {
    display: grid;
    gap: 0.9rem;
    border-radius: 28px;
    box-shadow: var(--shadow-glow);
    padding: clamp(1.1rem, 2.6vw, 1.6rem);
  }

  label {
    display: grid;
    gap: 0.38rem;
    color: var(--muted-dark);
    font-size: 0.92rem;
  }

  input,
  select {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--night-line);
    border-radius: 14px;
    background: rgba(214, 230, 255, 0.08);
    color: #EAF2FF;
    padding: 0.75rem 0.85rem;
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }

  input:focus,
  select:focus {
    border-color: rgba(63, 142, 252, 0.65);
    box-shadow: 0 0 0 3px rgba(46, 107, 246, 0.22);
    outline: none;
  }

  select option {
    background: var(--night);
    color: #EAF2FF;
  }

  button {
    position: relative;
    min-height: 52px;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--grad-brand);
    box-shadow: var(--shadow-glow);
    color: #fff;
    cursor: pointer;
    font-weight: 600;
    overflow: hidden;
    transition: transform 180ms ease;
  }

  button::before {
    position: absolute;
    inset: 0;
    content: "";
    transform: translateX(-110%) skewX(-16deg);
    background: linear-gradient(100deg, transparent 20%, rgba(255, 255, 255, 0.34) 50%, transparent 80%);
    transition: transform 700ms var(--ease-out);
  }

  button:hover::before {
    transform: translateX(110%) skewX(-16deg);
  }

  button:hover {
    transform: translateY(-2px);
  }

  .form-foot {
    margin: 0;
    color: var(--muted-dark);
    font-size: 0.85rem;
    text-align: center;
  }

  .form-note {
    margin: 0;
    border-radius: 12px;
    background: rgba(84, 207, 165, 0.13);
    color: var(--mint);
    font-size: 0.88rem;
    padding: 0.6rem 0.8rem;
    text-align: center;
  }

  @media (max-width: 860px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
