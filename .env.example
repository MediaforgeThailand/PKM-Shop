# ── Web app (Vite, client-safe) ───────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
VITE_TENANT_SLUG=pkm-shop

# ── Edge Function secrets (server-only — set via `supabase secrets set`) ────
# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI sales agent — Anthropic Messages API (Ready.md §2). The runtime model can also be
# changed per-tenant in Settings (app_settings.ai_model) without redeploying.
ANTHROPIC_API_KEY=sk-ant-your-key
AI_MODEL=claude-sonnet-4-6
# AI_REQUEST_TIMEOUT_MS=30000

# LINE OA (per-tenant supported via LINE_CHANNEL_SECRET__<slug>; single OA uses base)
# ⚠️ not yet obtained — leave blank to run the LINE layer in log-only/no-op mode.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
PKM_DEFAULT_TENANT_SLUG=pkm-shop

# SlipOK slip verification (Ready.md §7.1)
# ⚠️ not yet obtained — while blank, every slip goes to the manual-verify queue
# and payment stays staff-confirmed (slip-verify returns not_configured).
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=
