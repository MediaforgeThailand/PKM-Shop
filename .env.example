EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Model selection is safe to expose. The OpenAI key itself belongs in the
# Supabase Edge Function secret OPENAI_API_KEY, not in the mobile app.
EXPO_PUBLIC_OPENAI_MODEL=gpt-5.5
EXPO_PUBLIC_USER_NICKNAME=ลูกค้า

# Optional external backend path. If empty, the app calls the Supabase Edge
# Function named mira-chat through supabase.functions.invoke().
EXPO_PUBLIC_AI_PROXY_URL=

# Server-only Supabase Edge Function secrets for Stripe Checkout.
# Set these with `supabase secrets set`; do not expose them in Expo public env.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
MIRA_PUBLIC_APP_URL=https://your-app.example
